# Copy to .env and edit values. .env is gitignored.

# --- Database ---
POSTGRES_USER=thesis
POSTGRES_PASSWORD=thesis
POSTGRES_DB=thesis
# asyncpg driver URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://thesis:thesis@localhost:5433/thesis

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:26b
# Model used for transcript extraction (structured JSON output).
# Falls back to OLLAMA_CHAT_MODEL if left empty.
OLLAMA_EXTRACT_MODEL=
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
# Dimension must match the embed model: qwen3-embedding:4b=2560, nomic-embed-text=768, mxbai-embed-large=1024
OLLAMA_EMBED_DIM=2560

# --- CORS ---
# Comma-separated origins allowed for the React dev server
CORS_ORIGINS=http://localhost:5173
