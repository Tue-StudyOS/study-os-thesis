{
  "description": "Hooks für automatische project-context Updates mit Ruflo",
  "hooks": {
    "post-task": {
      "description": "Aktualisiert project-context nach jedem Task",
      "commands": [
        "npx ts-node .claude-flow/project-context.ts > /dev/null 2>&1 || true"
      ]
    },
    "on-swarm-init": {
      "description": "Lädt project-context vor SPARC-Task",
      "commands": [
        "npx ts-node .claude-flow/project-context.ts"
      ]
    },
    "pre-task": {
      "description": "Synchronisiert Memory mit project-context",
      "commands": [
        "node .claude-flow/sync-memory.js"
      ]
    }
  }
}
